# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vendorbridge:vendorbridge_pass@localhost:5432/vendorbridge?schema=public

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars-long-here
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-long-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
